{
  "uid": "jetstream-overview",
  "title": "JetStream Overview",
  "tags": ["nats", "jetstream", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "stream",
        "label": "Stream",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": [".*"]
        },
        "query": {
          "query": "label_values(jetstream_stream_total_messages, stream_name)",
          "refId": "Prometheus-stream-Variable-Query"
        }
      },
      {
        "name": "consumer",
        "label": "Consumer",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": ["All"],
          "value": [".*"]
        },
        "query": {
          "query": "label_values(jetstream_consumer_num_pending{stream_name=~\"$stream\"}, consumer_name)",
          "refId": "Prometheus-consumer-Variable-Query"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 5,
      "type": "timeseries",
      "title": "Messages Per Stream",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name) (jetstream_stream_total_messages{stream_name=~\"$stream\"})",
          "legendFormat": "{{stream_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Bytes Per Stream",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name) (jetstream_stream_total_bytes{stream_name=~\"$stream\"})",
          "legendFormat": "{{stream_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Consumers Per Stream",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name) (jetstream_stream_consumer_count{stream_name=~\"$stream\"})",
          "legendFormat": "{{stream_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Consumer Pending",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name, consumer_name) (jetstream_consumer_num_pending{stream_name=~\"$stream\",consumer_name=~\"$consumer\"})",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumer Ack Pending",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name, consumer_name) (jetstream_consumer_num_ack_pending{stream_name=~\"$stream\",consumer_name=~\"$consumer\"})",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Consumer Redelivered",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name, consumer_name) (jetstream_consumer_num_redelivered{stream_name=~\"$stream\",consumer_name=~\"$consumer\"})",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Consumer Waiting",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (stream_name, consumer_name) (jetstream_consumer_num_waiting{stream_name=~\"$stream\",consumer_name=~\"$consumer\"})",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
